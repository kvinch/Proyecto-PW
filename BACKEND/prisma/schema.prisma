// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider= "postgresql"
}

model User {
  id Int @id @default(autoincrement())
  usuario String @unique
  rol String
  estado String
  contrasena String
}

model Producto {
  id          Int    @id @default(autoincrement())
  nombre      String @unique
  categoria   String
  stock       Int
  stockMinimo Int
  unidad      String
  entradas    Entradas[]
  salidas     Salidas[]
}

model Entradas {

  id          Int    @id @default(autoincrement())
  cantidad    Int
  proveedor   String
  responsable String
  fecha       DateTime
  observacion String?
  productoId  Int
  producto    Producto @relation(fields: [productoId], references: [id])

}

model Salidas {

  id          Int    @id @default(autoincrement())
  cantidad    Int
  motivo      String
  responsable String
  fecha       DateTime
  observacion String?
  productoId  Int
  producto    Producto @relation(fields: [productoId], references: [id])

}
